# ============================================================================
# LiteLLM proxy environment
# Copy to .env and fill in real values:   cp .env.example .env
# ============================================================================

# ---- LiteLLM proxy / admin ----
# Master key: admin login + the default API key your clients send (must start with sk-)
LITELLM_MASTER_KEY=sk-CHANGE-ME-master
# Salt used to encrypt provider credentials stored in the DB (set once, keep stable)
LITELLM_SALT_KEY=sk-CHANGE-ME-salt
# Persist models/keys created via the admin UI
STORE_MODEL_IN_DB=True

# ---- Postgres (db service + LiteLLM) ----
POSTGRES_USER=litellm
POSTGRES_PASSWORD=CHANGE-ME-db-password
POSTGRES_DB=litellm
# Host port to reach this PG from your machine (container still listens on 5432 internally)
POSTGRES_HOST_PORT=5433
# Host is the compose service name "db". Keep password in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://litellm:CHANGE-ME-db-password@db:5432/litellm

# ---- Redis (only used if you enable caching in config.yaml) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# Claude Platform on AWS  (Anthropic-native API, billed via AWS Marketplace)
#   In the AWS Console -> Claude Platform on AWS:
#     - Workspaces -> API keys  ->  ANTHROPIC_AWS_API_KEY     (sent as x-api-key)
#     - Workspace ID            ->  ANTHROPIC_WORKSPACE_ID    (sent as anthropic-workspace-id)
#   Base URL pattern: https://aws-external-anthropic.<region>.api.aws
# ============================================================================
ANTHROPIC_AWS_API_KEY=sk-ant-CHANGE-ME
ANTHROPIC_WORKSPACE_ID=wrkspc-CHANGE-ME
CLAUDE_PLATFORM_AWS_BASE_URL=https://aws-external-anthropic.us-east-1.api.aws

# ============================================================================
# Amazon Bedrock  (Amazon Nova, via SigV4)
#   IAM principal needs bedrock:InvokeModel / bedrock:InvokeModelWithResponseStream
#   on the Nova model / inference-profile ARNs, in AWS_REGION_NAME.
# ============================================================================
AWS_ACCESS_KEY_ID=AKIA-CHANGE-ME
AWS_SECRET_ACCESS_KEY=CHANGE-ME
# ---- Bedrock region(s) ----
# Per-model regions live in models.yaml (each model carries its own region), NOT here.
# AWS_SESSION_TOKEN=        # only if using temporary STS credentials

# ============================================================================
# Bedrock Mantle  (GLM, OpenAI-compatible endpoint)
#   AWS_BEARER_TOKEN_BEDROCK = a Bedrock API key (Bedrock Console -> API keys
#   -> Generate). Used as the bearer token for the Mantle endpoint.
#   Base URL pattern: https://bedrock-mantle.<region>.api.aws/v1
# ============================================================================
AWS_BEARER_TOKEN_BEDROCK=CHANGE-ME-bedrock-api-key
# Mantle region is set PER-MODEL in config.yaml (in each GLM's api_base).
# Pattern (reference only): https://bedrock-mantle.<region>.api.aws/v1
